func TestUserHandlers_GetUser_InvalidID(t *testing.T) {
	repo := newMemoryUserRepo()
	h := UserHandlers{
		Create: useruc.CreateUser{Repo: repo},
		Get:    useruc.GetUser{Repo: repo},
	}
	req := httptest.NewRequest(http.MethodGet, "/v1/users/not-a-uuid", nil)
